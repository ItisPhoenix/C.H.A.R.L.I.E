{
  "name": "charlie-buddy",
  "version": "0.1.0",
  "description": "Charlie Desktop Buddy UI - Always-on-top transparent robot companion",
  "main": "out/main/main.mjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.charlie.buddy",
    "productName": "Charlie Buddy",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "gsap": "^3.12.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socket.io-client": "^4.7.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "electron-vite": "^3.0.0",
    "vite": "^8.0.16"
  }
}
