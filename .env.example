LLM_URL=your_llm_base_url_here
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=your_llm_model_id

# ── FAST LLM (Optional) ─────────────────────────────────────────────────────
# Leave blank to disable fast-LLM routing.
FAST_LLM_URL=your_fast_llm_base_url_here
FAST_LLM_API_KEY=your_fast_llm_api_key_here
FAST_LLM_MODEL=your_fast_llm_model_id

# ── SEARCH PROVIDERS ──────────────────────────────────────────────────────
# SearXNG self-hosted instance (first priority, no API key needed).
# Leave blank to skip; fallback order: SearXNG → Exa → Tavily → DuckDuckGo.
SEARXNG_URL=http://your-searxng-server:8080
# EXA_API_KEY=your_exa_api_key_here
# TAVILY_API_KEY=your_tavily_api_key_here

# ── HARDWARE / DEVICE SETTINGS ──────────────────────────────────────────────
# -1 = System default; >=0 = Specific device index
MIC_INDEX=-1
OUTPUT_INDEX=-1
GPU_DEVICE=cuda

# ── SPEECH SETTINGS (ASR/TTS) ───────────────────────────────────────────────
WHISPER_MODEL=distil-large-v3
KOKORO_VOICE=af_heart
KOKORO_MODEL_DIR=models

# Voice Activity Detection (VAD)
VAD_THRESHOLD=0.75
VAD_SILENCE_TIMEOUT=1.2
PHRASE_MIN_DURATION=0.8
PHRASE_MAX_DURATION=30.0

# ── BARGE-IN ────────────────────────────────────────────────────────────────
ENABLE_BARGE_IN=true

# ── LLM REASONING TOGGLE ─────────────────────────────────────────────────────
# Disable chain-of-thought/reasoning for lower voice latency.
LLM_DISABLE_REASONING=true
FAST_LLM_DISABLE_REASONING=true

# ── HUGGINGFACE TOKEN (for model downloads) ─────────────────────────────────
HF_TOKEN=your_hf_token_here

# ── MEMORY AND HISTORY ──────────────────────────────────────────────────────
# MEMORY_FILE=MEMORY.md
# USER_FILE=USER.md
# PROMPT_MEMORY_MAX=2200
# SESSION_DB_PATH=sessions.db
