LLM_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=your_nvidia_api_key
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b

# Hardware / Device settings
MIC_INDEX=0
OUTPUT_INDEX=0
GPU_DEVICE=cuda

# Speech Settings
KOKORO_VOICE=af_heart
KOKORO_MODEL_DIR=models
WHISPER_MODEL=distil-large-v3

# Research Settings
SEARXNG_URL=http://localhost:8081/
RESEARCH_MEMORY_DB=research_memory.db
DATA_DIR=charlie/data

# Backend Model routing (fast_path for summarization)
# Hybrid Model Routing (Local for utility, Cloud for depth)
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.1:8b
LOCAL_LLM_KEY=no-key
ENABLE_LOCAL_LLM=true

# Cloud Model routing (same API as main)
FAST_LLM_URL=https://api.groq.com/openai/v1
FAST_LLM_KEY=your_groq_key
FAST_LLM_MODEL=llama-3.1-8b-instant

# Passive Attention & Tools
MCP_CONFIG_PATH=mcp_config.json
