# ── BRAIN (LLM) SETTINGS ───────────────────────────────────────────────────
LLM_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=meta/llama3-70b-instruct

# Fast Path (for background tasks like summarization/fact-extraction)
FAST_LLM_URL=https://integrate.api.nvidia.com/v1
FAST_LLM_KEY=your_fast_llm_api_key_here
FAST_LLM_MODEL=meta/llama3-8b-instruct

# Local LLM Routing (Optional: for cost efficiency)
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.1:8b
LOCAL_LLM_KEY=no-key
ENABLE_LOCAL_LLM=true
HYBRID_ROUTING=keyword

# ── HARDWARE / DEVICE SETTINGS ──────────────────────────────────────────────
# -1 = System default; >=0 = Specific device index
MIC_INDEX=-1
OUTPUT_INDEX=-1
GPU_DEVICE=cuda

# ── SPEECH SETTINGS (ASR/TTS) ───────────────────────────────────────────────
WHISPER_MODEL=distil-large-v3
KOKORO_VOICE=af_heart
KOKORO_MODEL_DIR=models

# Voice Activity Detection (VAD)
VAD_THRESHOLD=0.75
VAD_SILENCE_TIMEOUT=1.2
PHRASE_MIN_DURATION=0.8
PHRASE_MAX_DURATION=30.0

# ── SENSES & TOOLS ──────────────────────────────────────────────────────────
# Passive Attention
ENABLE_WAKE_WORD=false
WAKE_WORD_MODEL=charlie/charlie.onnx
WAKE_WORD_SENSITIVITY=0.5
SMART_MODE_TIMEOUT=15.0

# Research (SearXNG)
SEARXNG_URL=http://localhost:8080/

# MCP Tools
MCP_CONFIG_PATH=mcp_config.json

# ── DATA & STORAGE ───────────────────────────────────────────────────────────
DATA_DIR=charlie/data
CHARLIE_MEMORY_DB=charlie_memory.db
RESEARCH_MEMORY_DB=research_memory.db
HISTORY_FILE=charlie_history.json
MAX_HISTORY=12

# ── PERSONALITY & IDENTITY ──────────────────────────────────────────────────
CHARLIE_SOUL_PATH=SOUL.md
CHARLIE_USER_PATH=USER.md
DEFAULT_LANGUAGE=en
ENABLE_SEMANTIC_MEMORY=true
CHARLIE_MEMORY_AUTO_EXTRACT=true
