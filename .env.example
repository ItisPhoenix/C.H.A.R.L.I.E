# -- SMALL LLM (fast/local) ----------------
SMALL_LLM_URL=your_llm_base_url_here
SMALL_LLM_API_KEY=your_llm_api_key_here
SMALL_LLM_MODEL=your_llm_model_id

# Big LLM (used when small LLM fails)
BIG_LLM_URL=your_big_llm_base_url_here
BIG_LLM_API_KEY=no-key
BIG_LLM_MODEL=your_big_model_id

# ── SEARCH PROVIDERS ──────────────────────────────────────────────────────
# SearXNG self-hosted instance (first priority, no API key needed).
# Leave blank to skip; fallback order: SearXNG → Exa → Tavily → DuckDuckGo.
SEARXNG_URL=http://your-searxng-server:8080
# EXA_API_KEY=your_exa_api_key_here
# TAVILY_API_KEY=your_tavily_api_key_here

# ── HARDWARE / DEVICE SETTINGS ──────────────────────────────────────────────
# -1 = System default; >=0 = Specific device index
MIC_INDEX=-1
GPU_DEVICE=cuda

# ── RUNTIME / SERVER ────────────────────────────────────────────────────────
# Bind host/port for the dashboard web server (localhost-only by default).
# CHARLIE_HOST=127.0.0.1
# CHARLIE_PORT=8000
# onnxruntime log verbosity (0=verbose .. 4=error)
# ORT_LOG_LEVEL=3
# Default UI language tag (BCP-47, e.g. en-US)
# DEFAULT_LANGUAGE=en-US
# TTS language code passed to Kokoro
# KOKORO_LANG=en

# ── SPEECH SETTINGS (ASR/TTS) ───────────────────────────────────────────────
WHISPER_MODEL=large-v3
KOKORO_VOICE=af_heart
KOKORO_MODEL_DIR=models

# Voice Activity Detection (VAD)
VAD_THRESHOLD=0.25
VAD_SILENCE_TIMEOUT=1.5
PHRASE_MIN_DURATION=0.35
PHRASE_MAX_DURATION=45.0

# ASR accuracy tuning (higher = better quality, slightly more latency)
ASR_BEAM_SIZE=6
ASR_BEST_OF=6
ASR_REPETITION_PENALTY=1.15
VAD_MIN_SPEECH_DURATION_MS=120
VAD_MAX_SPEECH_DURATION_S=60
VAD_MIN_SILENCE_DURATION_MS=1000
VAD_SPEECH_PAD_MS=320

# ── BARGE-IN ────────────────────────────────────────────────────────────────
ENABLE_BARGE_IN=true

# ── LLM REASONING TOGGLE ─────────────────────────────────────────────────────
# Disable chain-of-thought/reasoning for lower voice latency.
SMALL_LLM_DISABLE_REASONING=true

# Enable native JSON tool calling for compatible remote APIs.
# Set to false for local models (Ollama) that use text-based TOOL: parsing.
NATIVE_TOOL_CALLING=true

# ── HUGGINGFACE TOKEN (for model downloads) ─────────────────────────────────
# Get yours at: https://huggingface.co/settings/tokens
# HF_TOKEN=your_token_here
# ── MEMORY AND HISTORY ──────────────────────────────────────────────────────
# MEMORY_FILE=MEMORY.md
# USER_FILE=USER.md
# OPINIONS_FILE=OPINIONS.md
# PROMPT_MEMORY_MAX=2200
# SESSION_DB_PATH=sessions.db

# ── ITERATION BUDGET & COMPRESSION ──────────────────────────────────────────
# ITERATION_BUDGET_MAX=12
# CONTEXT_WINDOW=8192
# COMPRESSION_THRESHOLD=0.8
# HISTORY_KEEP_RECENT=6
# HISTORY_SUMMARY_MAX_CHARS=400
# -- WAKE WORD (optional) ───────────────────────────────────────────────────
# Enable wake-word detection (hands-free activation)
WAKE_WORD_ENABLED=false
# Path to wake-word classifier ONNX model
WAKE_WORD_MODEL_PATH=charlie/charlie.onnx
# Detection threshold (0.0 - 1.0, higher = fewer false triggers)
WAKE_WORD_THRESHOLD=0.6
# Seconds of inactivity before returning to wake-word listening mode
WAKE_WORD_ACTIVITY_TIMEOUT=600
# Path to audio chime played on wake-word detection (optional)
WAKE_WORD_CHIME_PATH=assets/wake_word_chime.wav

# --- VECTOR MEMORY (optional) ---
# Enable/disable auto-extraction of facts from conversations
# MEMORY_AUTO_EXTRACT=true
# ChromaDB storage path
# MEMORY_DB_PATH=charlie_memory_db
# Semantic similarity threshold (lower = stricter matching)
# MEMORY_RELEVANCE_THRESHOLD=0.3
# Embedding model and service URL
# MEMORY_EMBEDDING_MODEL=nomic-embed-text:v1.5
# MEMORY_EMBEDDING_URL=http://localhost:11434
# Knowledge-graph SQLite path
# MEMORY_GRAPH_DB=charlie_memory_graph.db
# Seconds between periodic memory consolidation passes
# MEMORY_NUDGE_INTERVAL=180
# Soft cap on stored memory entries before consolidation prunes oldest
# MEMORY_CAPACITY_THRESHOLD=300
 
 # ── AGENTIC OS TOGGLES ─────────────────────────────────────────────────────
 # Enable/disable the Blackboard pattern for agent coordination
 # BLACKBOARD_ENABLED=true
 # Enable/disable MCP (Model Context Protocol) client
 # MCP_ENABLED=false
# Comma-separated MCP server specs; each is "name|command|arg1,arg2,...".
# Empty means no servers are started even when MCP_ENABLED=true.
# MCP_SERVERS=
 # Enable/disable Hybrid Plugin system
 # PLUGINS_ENABLED=false
 # Comma-separated directories the plugin filesystem tools may access.
 # Leave blank to restrict plugins to the current working directory only.
 # PLUGIN_ALLOW_DIRS=/path/one,/path/two

