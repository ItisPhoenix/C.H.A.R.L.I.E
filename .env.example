# ============================================================
# C.H.A.R.L.I.E. — Environment Variables Template
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# ============================================================

# --- LLM Backend (OpenAI-compatible, e.g. LM Studio / Ollama) ---
LLM_URL=http://localhost:1234

# --- NIM (NVIDIA NIM / cloud LLM) ---
NIM_BASE_URL=https://integrate.api.nvidia.com
NIM_API_KEY=
NIM_PRIMARY_MODEL=

# --- OpenRouter (free tier vision model) ---
OPENROUTER_API_KEY=

# --- Google Gemini (free tier, gemini-2.5-flash + Gemini Live) ---
GEMINI_API_KEY=

# --- Groq (free tier, fast inference) ---
GROQ_API_KEY=

# --- Vision Model (separate endpoint, e.g. LM Studio) ---
VISION_LLM_URL=http://127.0.0.1:1234/v1
VISION_MODEL=

# --- Embeddings ---
EMBEDDING_URL=http://127.0.0.1:1234/api/embeddings
EMBEDDING_MODEL=

# --- Telegram Bot ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- Spotify ---
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# --- GitHub ---
GITHUB_TOKEN=

# --- Notion ---
NOTION_TOKEN=

# --- Google OAuth (optional, for Gmail + Calendar integrations) ---
# Place credentials.json in config/secure/ for OAuth flow
# GOOGLE_CREDENTIALS_PATH=config/secure/credentials.json

# --- CUDA (auto-detected, override if needed) ---
# CUDNN_PATH=
# CUDA_PATH=